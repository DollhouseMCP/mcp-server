# ============================================================================
# DollhouseMCP Personal Configuration Template
# ============================================================================
# Copy this file to .env.local and fill in your actual values:
#   cp .env.example .env.local
#
# IMPORTANT: Never commit .env.local to git! It contains your personal secrets.
#
# All default configuration values are in the .env file (which is committed).
# This file is only for values that are personal/secret and vary per developer.
# ============================================================================

# ============================================================================
# GitHub Authentication - Production Account
# ============================================================================
# Generate token at: https://github.com/settings/tokens
# Required scopes: repo, read:org
# Use your REAL GitHub account credentials for development

GITHUB_TOKEN=ghp_your_production_token_here
GITHUB_USERNAME=your-github-username

# Portfolio repository name (RECOMMENDED - avoids conflicts with GitHub Actions)
# Use this instead of GITHUB_REPOSITORY to avoid confusion with GitHub Actions' "owner/repo" format
PORTFOLIO_REPOSITORY_NAME=dollhouse-portfolio

# ============================================================================
# GitHub Authentication - Test Account (DIFFERENT from production!)
# ============================================================================
# IMPORTANT: Create a SEPARATE GitHub account for testing
# Generate test token at: https://github.com/settings/tokens
# Use this dedicated test account to avoid polluting production data
# Tests will skip gracefully if these are not set
#
# NOTE: GITHUB_TEST_REPOSITORY should be JUST the repository name (not "owner/repo")
# The username is specified separately in GITHUB_TEST_USERNAME

GITHUB_TEST_TOKEN=ghp_your_test_token_here
GITHUB_TEST_USERNAME=test-username
GITHUB_TEST_REPOSITORY=dollhouse-test-sandbox

# ============================================================================
# User Information (Optional)
# ============================================================================
# Used for attribution in commits and submissions

DOLLHOUSE_USER=your-username
DOLLHOUSE_EMAIL=your-email@example.com

# ============================================================================
# Custom Directory Paths (Optional)
# ============================================================================
# Override default paths if needed
# Defaults are: ~/.dollhouse/*, .test-tmp/* (for tests)

# DOLLHOUSE_HOME_DIR=/custom/home/path
# DOLLHOUSE_PORTFOLIO_DIR=/custom/portfolio/path
# DOLLHOUSE_CACHE_DIR=/custom/cache/path
# DOLLHOUSE_PORTFOLIO_URL=https://github.com/username/portfolio

# ============================================================================
# OAuth Configuration (Optional)
# ============================================================================
# Only needed if using GitHub OAuth device flow authentication

# DOLLHOUSE_GITHUB_CLIENT_ID=your_oauth_client_id

# ============================================================================
# Personal Overrides (Optional)
# ============================================================================
# Override any default from .env file for your personal setup
# Examples:

# LOG_LEVEL=debug
# ENABLE_DEBUG=true
# DOLLHOUSE_INDICATOR_ENABLED=false
# DOLLHOUSE_MAX_PERSONA_CACHE_SIZE=100

# Active element limits (soft limits that trigger cleanup of stale entries)
# Values are clamped to safety floors and security ceilings.
# See docs/reference/environment-vars.md for details.
# DOLLHOUSE_MAX_ACTIVE_SKILLS=200
# DOLLHOUSE_MAX_ACTIVE_AGENTS=100
# DOLLHOUSE_MAX_ACTIVE_MEMORIES=100
# DOLLHOUSE_MAX_ACTIVE_ENSEMBLES=50
# DOLLHOUSE_MAX_ACTIVE_PERSONAS=20

# ============================================================================
# Metrics Collection (Optional)
# ============================================================================
# DOLLHOUSE_METRICS_ENABLED=true
# DOLLHOUSE_METRICS_COLLECTION_INTERVAL_MS=15000
# DOLLHOUSE_METRICS_MEMORY_SNAPSHOT_CAPACITY=240
# DOLLHOUSE_METRICS_MAX_SNAPSHOT_SIZE=102400
# DOLLHOUSE_METRICS_COLLECTOR_FAILURE_THRESHOLD=10
# DOLLHOUSE_METRICS_COLLECTION_DURATION_WARN_MS=5000

# See .env file for all available configuration options
# ============================================================================
