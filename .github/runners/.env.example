# GitHub Actions Self-Hosted Runner Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Create a Personal Access Token (PAT) with 'repo' scope:
#   1. Go to: https://github.com/settings/tokens/new
#   2. Select scopes: 'repo' (full control of private repositories)
#   3. Generate token and copy it below
#
# Or use GitHub CLI:
#   gh auth token  # If your existing token has repo scope

# GitHub Personal Access Token with 'repo' scope (required)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# Runner name (shows in GitHub UI)
RUNNER_NAME=dollhouse-mac-runner
