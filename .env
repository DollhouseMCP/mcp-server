# ============================================================================
# DollhouseMCP Default Configuration
# ============================================================================
# This file contains sensible defaults for all configuration options.
# It is safe to commit to git (contains NO secrets).
#
# To override any value, create a .env.local file with your changes.
# .env.local has priority and should contain your personal secrets.
#
# See .env.example for a template of personal configuration.
# ============================================================================

# ============================================================================
# Basic Configuration
# ============================================================================

# Environment mode (development | test | production)
NODE_ENV=development

# Server port
PORT=3000

# Logging level (error | warn | info | debug)
LOG_LEVEL=info

# Enable debug mode (verbose logging, stack traces)
ENABLE_DEBUG=false

# ============================================================================
# GitHub API Configuration
# ============================================================================

# GitHub API timeout (milliseconds)
DOLLHOUSE_GITHUB_API_TIMEOUT=30000

# GitHub API rate limits
DOLLHOUSE_GITHUB_RATE_LIMIT_AUTH=5000
DOLLHOUSE_GITHUB_RATE_LIMIT_UNAUTH=60

# Minimum delay between GitHub API requests (milliseconds)
DOLLHOUSE_GITHUB_MIN_DELAY=1000

# Rate limit buffer percentage (0.0-1.0)
DOLLHOUSE_GITHUB_RATE_BUFFER=0.9

# Enable GitHub GraphQL API (true | false)
# DOLLHOUSE_GITHUB_GRAPHQL=false

# ============================================================================
# Feature Flags
# ============================================================================

# Auto-submit new elements to DollhouseMCP community collection
DOLLHOUSE_AUTO_SUBMIT_TO_COLLECTION=false

# Enable file watcher for hot-reloading
DOLLHOUSE_ENABLE_FILE_WATCHER=true

# Disable auto-loading of elements on startup
DOLLHOUSE_DISABLE_AUTOLOAD=false

# Enable security alerts
DOLLHOUSE_SECURITY_ALERTS=true

# Disable element filtering
DISABLE_ELEMENT_FILTERING=false

# Auto-reload on external file changes
AUTO_RELOAD_ON_EXTERNAL_CHANGE=true

# ============================================================================
# Cache Configuration
# ============================================================================

# Persona cache limits
DOLLHOUSE_MAX_PERSONA_CACHE_SIZE=50
DOLLHOUSE_MAX_PERSONA_CACHE_MEMORY=25

# Metrics cache limits
DOLLHOUSE_MAX_METRICS_CACHE_SIZE=100
DOLLHOUSE_MAX_METRICS_CACHE_MEMORY=1

# Search cache limits
DOLLHOUSE_MAX_SEARCH_CACHE_SIZE=100
DOLLHOUSE_MAX_SEARCH_CACHE_MEMORY=10

# Index cache limits
DOLLHOUSE_MAX_INDEX_CACHE_SIZE=50
DOLLHOUSE_MAX_INDEX_CACHE_MEMORY=25

# API response cache limits
DOLLHOUSE_MAX_API_CACHE_SIZE=200
DOLLHOUSE_MAX_API_CACHE_MEMORY=5

# Cache TTL (time-to-live) in milliseconds
ELEMENT_CACHE_TTL_MS=300000
ELEMENT_PATH_CACHE_TTL_MS=300000

# Cache sample size for balanced memory estimation
DOLLHOUSE_CACHE_SAMPLE_SIZE=10

# ============================================================================
# File Locking Configuration
# ============================================================================

# Lock acquisition timeout (milliseconds)
DOLLHOUSE_LOCK_TIMEOUT=10000

# Stale lock cleanup threshold (milliseconds)
DOLLHOUSE_LOCK_STALE_THRESHOLD=60000

# Maximum retry attempts for lock acquisition
DOLLHOUSE_LOCK_MAX_RETRIES=3

# Initial retry delay with exponential backoff (milliseconds)
DOLLHOUSE_LOCK_RETRY_DELAY=100

# ============================================================================
# Metrics Configuration
# ============================================================================

# Number of metrics to batch before flushing
DOLLHOUSE_METRICS_BATCH_SIZE=10

# Force flush interval even if batch not full (milliseconds)
DOLLHOUSE_METRICS_FLUSH_INTERVAL=5000

# ============================================================================
# Retry Configuration
# ============================================================================

# Maximum retry attempts for failed operations
DOLLHOUSE_MAX_RETRY_ATTEMPTS=3

# Initial retry delay (milliseconds)
DOLLHOUSE_INITIAL_RETRY_DELAY=1000

# Maximum retry delay (milliseconds)
DOLLHOUSE_MAX_RETRY_DELAY=10000

# ============================================================================
# File Size Limits
# ============================================================================

# Maximum file size for uploads/processing (bytes)
DOLLHOUSE_MAX_FILE_SIZE=10485760

# ============================================================================
# Search & Similarity Configuration
# ============================================================================

# Minimum similarity score for search results (0.0-1.0)
DOLLHOUSE_MIN_SIMILARITY=0.3

# Maximum number of search suggestions
DOLLHOUSE_MAX_SUGGESTIONS=10

# Search result source priority (local | github | collection)
SOURCE_PRIORITY=local

# ============================================================================
# Collection Configuration
# ============================================================================

# Collection fetch timeout (milliseconds)
COLLECTION_FETCH_TIMEOUT=30000

# ============================================================================
# Status Indicator Configuration
# ============================================================================
# Controls the status line display in MCP clients

# Enable/disable status indicator
DOLLHOUSE_INDICATOR_ENABLED=true

# Display style (full | minimal | compact | custom)
DOLLHOUSE_INDICATOR_STYLE=full

# Custom format string (only used when style=custom)
# Variables: {persona}, {emoji}, {author}, {category}, {version}
# DOLLHOUSE_INDICATOR_FORMAT={emoji} {persona} by {author}

# Default emoji for personas
DOLLHOUSE_INDICATOR_EMOJI=🤖

# Bracket style for indicator (square | round | angle | none)
DOLLHOUSE_INDICATOR_BRACKETS=square

# Show persona author in indicator
DOLLHOUSE_INDICATOR_SHOW_AUTHOR=true

# Show persona category in indicator
DOLLHOUSE_INDICATOR_SHOW_CATEGORY=false

# Show persona version in indicator
DOLLHOUSE_INDICATOR_SHOW_VERSION=false

# ============================================================================
# Test Configuration
# ============================================================================
# These are automatically set by the test framework
# You usually don't need to change these manually

# Enable verbose logging in tests
TEST_VERBOSE_LOGGING=false

# Test mode (unit | integration | e2e)
# TEST_MODE=unit

# ============================================================================
# Telemetry Configuration (Optional)
# ============================================================================
# Telemetry is disabled by default and requires explicit opt-in

# Enable telemetry collection
DOLLHOUSE_TELEMETRY_ENABLED=false

# Opt-in to telemetry (requires explicit consent)
# DOLLHOUSE_TELEMETRY_OPTIN=false

# Disable remote telemetry (local only)
# DOLLHOUSE_TELEMETRY_NO_REMOTE=true

# Telemetry endpoint URL
# DOLLHOUSE_TELEMETRY_ENDPOINT=

# Legacy telemetry flag (use DOLLHOUSE_TELEMETRY_ENABLED instead)
# DOLLHOUSE_TELEMETRY=false

# ============================================================================
# Advanced Configuration (Rarely Changed)
# ============================================================================

# Load test data on startup (for development/testing)
# DOLLHOUSE_LOAD_TEST_DATA=false

# Force production mode even in development
# FORCE_PRODUCTION_MODE=false

# OAuth helper process management
# DOLLHOUSE_OAUTH_HELPER=auto

# Maximum file size for encryption operations (bytes)
# DOLLHOUSE_MAX_FILE_SIZE=10485760

# ============================================================================
# Personal Configuration (Use .env.local instead!)
# ============================================================================
# DO NOT set these values in this file - they contain secrets!
# Create a .env.local file with these instead:
#
# GITHUB_TOKEN=ghp_your_production_token
# GITHUB_USERNAME=your-github-username
# GITHUB_REPOSITORY=dollhouse-portfolio
#
# GITHUB_TEST_TOKEN=ghp_your_test_token
# GITHUB_TEST_USERNAME=test-username
# GITHUB_TEST_REPOSITORY=dollhouse-test-sandbox
#
# DOLLHOUSE_USER=your-username
# DOLLHOUSE_EMAIL=your-email@example.com
# DOLLHOUSE_HOME_DIR=/custom/home/path
# DOLLHOUSE_PORTFOLIO_DIR=/custom/portfolio/path
# DOLLHOUSE_CACHE_DIR=/custom/cache/path
# DOLLHOUSE_PORTFOLIO_URL=https://github.com/username/portfolio
#
# See .env.example for more details.
# ============================================================================
